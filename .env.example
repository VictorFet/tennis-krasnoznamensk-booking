# ----------------------------
# Application
# ----------------------------
NODE_ENV="development"
PORT="3000"
NEXT_TELEMETRY_DISABLED="1"

# ----------------------------
# Database (PostgreSQL)
# Example for local machine:
#   user: postgres
#   password: postgres
#   db: tennis_booking
# ----------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tennis_booking?schema=public"

# ----------------------------
# Seed admin credentials
# These are used by `npm run prisma:seed`
# ----------------------------
ADMIN_LOGIN="admin"
ADMIN_PASSWORD="change-me-please"
